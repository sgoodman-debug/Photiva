        <!-- ============================================================
             HOW TO SHIP AN UPDATE
             ============================================================
             1. Build a Release archive in Xcode → export as "Developer ID"
             2. Zip the .app: ditto -c -k --sequesterRsrc --keepParent Photiva.app Photiva-X.Y.zip
             3. Generate the EdDSA signature:
                    /tmp/Sparkle-2.9.0/bin/sign_update Photiva-X.Y.zip
             4. Upload the zip to the photivareleases repo
             5. Duplicate the latest <item> below, fill in version/url/length/signature
             6. Commit this file and push — Vercel will deploy the updated appcast
             ============================================================ -->

        <item>
            <title>Version 1.0.1</title>
            <description><![CDATA[
                <h2>What's New in 1.0.1</h2>
                <ul>
                    <li>Live Photo and Screenshot on-demand scanning</li>
                    <li>Improved location cleanup with horizontal chips and white pins</li>
                    <li>Organize: video separation, background preview generation</li>
                    <li>Glass card UI for scan progress views</li>
                    <li>Geocoding rate limiting to prevent throttling</li>
                    <li>License activation works offline</li>
                </ul>
            ]]></description>
